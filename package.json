{
  "name": "tahaddi",
  "version": "0.1.0",
  "private": true,
  "description": "Tahaddi — real-time multiplayer trivia & elimination game",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:server": "pnpm --filter @tahaddi/server dev",
    "dev:screen": "pnpm --filter @tahaddi/screen dev",
    "dev:controller": "pnpm --filter @tahaddi/controller dev",
    "dev:admin": "pnpm --filter @tahaddi/admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "pnpm --filter @tahaddi/server db:migrate",
    "db:seed": "pnpm --filter @tahaddi/server db:seed",
    "db:studio": "pnpm --filter @tahaddi/server db:studio",
    "db:reset": "pnpm --filter @tahaddi/server db:reset"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
