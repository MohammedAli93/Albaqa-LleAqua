# ───────────────────────────────────────────────────────────────────────────
# Tahaddi — environment configuration
# Copy to `.env` for local development. The server validates these at boot
# (apps/server/src/config/env.ts) and refuses to start if any are invalid.
# ───────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Public URLs (used for CORS allowlist, QR codes, links)
PUBLIC_API_URL=http://localhost:8080
PUBLIC_SCREEN_URL=http://localhost:5173
PUBLIC_CONTROLLER_URL=http://localhost:5174
PUBLIC_ADMIN_URL=http://localhost:5175

# Database (matches docker-compose)
DATABASE_URL=postgresql://tahaddi:tahaddi_dev_pw@localhost:5432/tahaddi?schema=public

# Redis (matches docker-compose)
REDIS_URL=redis://:tahaddi_dev_pw@localhost:6379

# JWT / auth secrets — CHANGE IN PRODUCTION (min 32 chars)
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_chars_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Token/secret hashing pepper for capability tokens (host/session)
TOKEN_PEPPER=dev_pepper_change_me_min_16

# S3 / object storage (matches MinIO in docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tahaddi-media
S3_ACCESS_KEY=tahaddi
S3_SECRET_KEY=tahaddi_dev_pw
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/tahaddi-media

# Seed super admin (created idempotently by `pnpm db:seed`)
SEED_ADMIN_EMAIL=admin@tahaddi.app
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin

# Payments (Stripe reference adapter; leave blank to disable)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability (optional locally)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=tahaddi-server

# Game tuning defaults (overridable per game)
GAME_MAX_PLAYERS=100
GAME_DEFAULT_TIMER_SEC=15
GAME_RECONNECT_GRACE_SEC=45
GAME_ROOM_TTL_SEC=7200
