{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@tahaddi/shared": ["packages/shared/src/index.ts"],
      "@tahaddi/shared/*": ["packages/shared/src/*"],
      "@tahaddi/ui": ["packages/ui/src/index.ts"],
      "@tahaddi/ui/*": ["packages/ui/src/*"],
      "@tahaddi/i18n": ["packages/i18n/src/index.ts"],
      "@tahaddi/i18n/*": ["packages/i18n/src/*"]
    }
  }
}
